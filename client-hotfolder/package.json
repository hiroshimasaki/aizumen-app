{
    "name": "aizumen-hotfolder",
    "version": "1.2.2",
    "description": "AiZumen HotFolder Monitoring Client",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "dist": "electron-packager . AiZumen-HotFolder --platform=win32 --arch=x64 --out=dist --overwrite",
        "build": "electron-builder build --win --x64"
    },
    "keywords": [],
    "license": "ISC",
    "dependencies": {
        "axios": "^1.6.0",
        "chokidar": "^3.5.3",
        "form-data": "^4.0.0",
        "node-notifier": "^10.0.1",
        "pdf-lib": "^1.17.1"
    },
    "devDependencies": {
        "electron": "^27.3.11",
        "electron-builder": "^26.8.1",
        "electron-packager": "^17.1.2"
    },
    "author": "AiZumen Team",
    "build": {
        "appId": "com.aizumen.hotfolder",
        "productName": "AiZumen-HotFolder",
        "copyright": "Copyright © 2024 AiZumen Team",
        "directories": {
            "output": "dist"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true
        },
        "files": [
            "**/*"
        ]
    }
}
